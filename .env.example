# Supabase — create project at supabase.com
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat — create project at app.revenuecat.com
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_ios_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_android_key

# OpenAI — for voice transcription (used in Supabase Edge Function only)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic — for voice log parsing (used in Supabase Edge Function only)
ANTHROPIC_API_KEY=sk-ant-your-key
