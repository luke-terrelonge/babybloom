{
  "expo": {
    "name": "BabyBloom",
    "slug": "babybloom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "babybloom",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.babybloom.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.babybloom.app",
      "adaptiveIcon": {
        "backgroundColor": "#E0F2F1",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-web-browser",
      "expo-sharing",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "BabyBloom needs photo access to add your baby's profile picture.",
          "cameraPermission": "BabyBloom needs camera access to take your baby's photo."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "BabyBloom needs microphone access for voice logging."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4DB6AC",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ccd64b1-9ee5-4739-ae8a-8197202b21d6"
      }
    },
    "owner": "lterrelonge"
  }
}
